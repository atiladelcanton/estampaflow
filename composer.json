{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "delka/estamparia",
    "type": "project",
    "description": "SaaS multi-tenant para gestão de estamparias — Delka Estamparia Sprint 1.",
    "keywords": [
        "laravel",
        "livewire",
        "saas",
        "estamparia",
        "multi-tenant",
        "design-system"
    ],
    "license": "proprietary",
    "require": {
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.17",
        "laravel/tinker": "^3.0",
        "livewire/flux": "^2.13.1",
        "livewire/livewire": "^4.1",
        "php": "^8.3",
        "stancl/tenancy": "^3.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.5.23",
        "rector/rector": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --seed --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd\" \"php artisan serve\" \"npm run dev\" --names=server,vite --kill-others"
        ],
        "lint": "pint",
        "lint:check": "pint --test",
        "types:check": "phpstan analyse",
        "refactor:check": "rector process --dry-run",
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "quality": [
            "@lint:check",
            "@types:check",
            "@refactor:check",
            "@php artisan docs:check",
            "@test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
