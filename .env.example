APP_NAME="Delka Estamparia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://app.estamparia.test:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=delka_estamparia
DB_USERNAME=delka
DB_PASSWORD=secret
DB_COLLATION=utf8mb4_0900_ai_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.estamparia.test
SESSION_SAME_SITE=lax
CACHE_STORE=database
QUEUE_CONNECTION=database

CENTRAL_DOMAIN=app.estamparia.test
CENTRAL_DOMAINS=app.estamparia.test
TENANT_BASE_DOMAIN=estamparia.test

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@delka.local
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
